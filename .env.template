# --- FinApp configuration template ---
# Copy this file to ".env" and fill in the values. Never commit ".env".

# Database
FINAPP_DB_PATH=./data/finapp.sqlite
FINAPP_DB_ENCRYPTION_ENABLED=false
# FINAPP_DB_PASSWORD=             # only if encryption enabled (prefer OS keychain)

# Locale / reporting
FINAPP_DEFAULT_LOCALE=pt_BR
FINAPP_REPORTING_CURRENCY=BRL     # BRL or USD

# FX
FINAPP_FX_PROVIDER=BCB_PTAX       # BCB_PTAX | ECB | YAHOO | MANUAL

# Market data
FINAPP_MARKET_PROVIDER=YAHOO
# ALPHAVANTAGE_API_KEY=

# AI / LLM (Azure OpenAI — same convention as agents/Foundry-test)
FINAPP_AI_ENABLED=true
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_API_KEY=

# Logging
FINAPP_LOG_LEVEL=INFO
